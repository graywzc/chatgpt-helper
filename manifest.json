{
  "manifest_version": 3,
  "name": "AI Chat Conversation Navigator",
  "version": "1.2.0",
  "description": "Adds a sidebar to ChatGPT, Claude and Gemini showing all your messages for quick navigation",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*", "https://claude.ai/*", "https://gemini.google.com/*"],
      "js": ["navigator-core.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Chat Navigator"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
