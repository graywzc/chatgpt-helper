{
  "manifest_version": 3,
  "name": "ChatGPT Conversation Navigator",
  "version": "1.0.0",
  "description": "Adds a sidebar to ChatGPT showing all your messages for quick navigation",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ChatGPT Navigator"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
